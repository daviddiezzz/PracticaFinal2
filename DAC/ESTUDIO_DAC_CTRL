Prescaler: Process(clk200,nRST)
begin
    if nRST ='0' then
        cntdiv8<=(others=>'0');
        clk25<='0';
    elsif rising_edge(clk200) then
        if cntdiv8= 3 then
           cntdiv8<=(others=>'0');
           clk25<= not clk25;
        else 
            cntdiv8<=cntdiv8 + 1;
        end if;
    end if;
end process;

CLK_OUT<=clk25;


P_S_FSM: Process(clk25,nRST)
begin
    if nRST ='0' then
        e_act<= IDLE;
    elsif rising_edge(clk25) then
        e_act<=e_sig;    
    end if;
end process;

P_C_FSM: Process(e_act, START,START1, shiftCounter)
begin
e_sig<=e_act;
   case e_act is
    when IDLE=>
        en_shift<='0';
        LoadData<='1';
        DONE<='1';
        nSYNQ<='1';
        
            if (START ='1' OR START1= '1') then
                e_sig<=SHIFTOUT;
            end if;
            
    when SHIFTOUT=>
        en_shift<='1';
        DONE<='0';
        LoadData<='0';
        nSYNQ<='0';
        
            if shiftCounter = 15 then
                e_sig<=SYNCDATA;
            end if;
            
     when SYNCDATA=>
        en_shift<='0';
        DONE<='0';
        LoadData<='0';
        nSYNQ<='1';
        
            if START='0' then
                e_sig<=IDLE;
            end if; 
             
     when others=>
            e_sig<=IDLE;
    end case;
end process;

SHIFTREG: Process(clk25)
    begin
    if rising_edge(clk25) then
    if LoadData = '1' then
           shiftRegister(15 downto 12) <= (others => '0');
           shiftRegister(11 downto 0) <= DATA1;
           shiftCounter <= "0000";
           
    elsif en_shift ='1' then      
       shiftRegister(15 downto 1) <= shiftRegister (14 downto 0);
       shiftRegister(0)<= shiftRegister(15);
       shiftCounter <= shiftCounter +1;
       end if;
       end if;
    end process;
    
D1<=ShiftRegister(15);


end Behavioral;
