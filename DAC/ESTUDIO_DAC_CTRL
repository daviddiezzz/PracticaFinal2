signal LoadData: std_logic;
signal en_shift: std_logic;
signal shiftCounter: unsigned (3 downto 0) := (others=>'0');
signal shiftRegister: std_logic_vector(15 downto 0):= (others=>'0');

-- prescaler
signal cntdiv8: unsigned(2 downto 0);
signal clk25: std_logic:='0';

--FSM
type estados is (IDLE,SHIFTOUT,SYNCDATA);
signal e_act, e_sig: estados;

begin


--U_ADDRCTRL : AddrCtrl
