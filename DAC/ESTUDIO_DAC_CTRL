           nRST : in STD_LOGIC;
           DATA1 : in STD_LOGIC_VECTOR (11 downto 0);
           START : in STD_LOGIC;
           START1: in STD_LOGIC;
           
           DONE : out STD_LOGIC;
           D1 : out STD_LOGIC;
           nSYNQ : out STD_LOGIC;
           CLK_OUT : out STD_LOGIC);
end ESTUDIO_DAC_CTRL;

