// Función para generar la rampa de 0 a 4095 en los 16k puntos
void generar_rampa(int tam, uint16_t* buffer) {
    for(int i = 0; i < tam; i++) {
        buffer[i] = (uint16_t)(( (uint32_t)i * 4095) / (tam - 1));
    }
}

// Función para generar una onda senoidal
void generar_seno(int tam, uint16_t* buffer) {
    float amplitud = 2047.0f;
    float offset   = 2047.0f;

    for(int i = 0; i < tam; i++) {
        float x = 2.0f * PI * ((float)i / (float)tam);

        // Aproximación rápida de seno si no puedes usar math.h
        // sin(x) approx x - x^3/6 + x^5/120
        // Pero lo mejor es arreglar el Linker (Paso 1)
        //float s = sin(x);
        buffer[i] = (uint16_t)(offset + amplitud * sin(x));
    }
}


