void generar_rampa_limpia(int tam, uint16_t* buffer) {
    for(int i = 0; i < tam; i++) {
        // Mapea el rango 0-16383 al rango 0-4095
        // (i / 16383.0) * 4095
        buffer[i] = (uint16_t)((i * 4095) / (tam - 1));
    }
}


