library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity Contador_START is
    Port ( 
        clk        : in  STD_LOGIC;   -- 100 MHz
        rst        : in  STD_LOGIC;   -- activo en '0'
        start_reg  : in  STD_LOGIC;   -- enable
        start_out  : out STD_LOGIC
    );
end Contador_START;

architecture Behavioral of Contador_START is

    signal contador : unsigned(10 downto 0) := (others => '0'); -- hasta 999
    signal start_int : STD_LOGIC := '0';

begin

process(clk, rst) 
begin
    if rst = '0' then
        contador <= (others => '0');

    elsif rising_edge(clk) then
        if contador = 999 then --19999 es para 10KHz y 1999 es para 100KHz 
            contador <= (others => '0');
        else
            contador <= contador + 1;
        end if;
    end if;
end process;

start_out <= '1' when contador = 999 else '0';  -- 200 ns

end Behavioral;
